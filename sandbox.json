{
  "enabled": true,
  "writablePaths": [
    "~/.cache",
    "~/.local",
    "~/.npm",
    "~/.mise",
    "~/.cargo",
    "~/.rustup",
    "~/.config",
    "~/.pi",
    "/var/tmp"
  ],
  "deniedPaths": [
    "~/.ssh",
    "~/.aws",
    "~/.gnupg",
    "~/.gemini",
    "~/.anthropic"
  ],
  "writeProtected": [
    ".env",
    ".env.*",
    "*.pem",
    "*.key",
    "*.secret"
  ],
  "restrictNetwork": false,
  "extraBwrapArgs": []
}
