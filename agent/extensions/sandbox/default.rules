{
  "rules": [
    {
      "pattern": ["rm", ["-rf", "-r", "--recursive"]],
      "decision": "prompt",
      "justification": "Recursive delete — check before proceeding",
      "excludePathPrefix": "/tmp/"
    },
    {
      "pattern": ["sudo"],
      "decision": "prompt",
      "justification": "Privilege escalation via sudo"
    },
    {
      "pattern": ["chmod", "*", "777"],
      "decision": "prompt",
      "justification": "World-writable permissions"
    },
    {
      "pattern": ["chmod", ["u+s", "g+s", "+s"]],
      "decision": "forbidden",
      "justification": "setuid/setgid privilege escalation"
    },
    {
      "pattern": ["chown"],
      "decision": "prompt",
      "justification": "Ownership changes require review"
    },
    {
      "pattern": ["git", "push", ["-f", "--force"]],
      "decision": "prompt",
      "justification": "Force push rewrites remote history"
    },
    {
      "pattern": ["git", "push", "--force"],
      "decision": "prompt",
      "justification": "Force push rewrites remote history"
    },
    {
      "pattern": ["mount"],
      "decision": "forbidden",
      "justification": "Mount operations can bypass sandbox restrictions"
    },
    {
      "pattern": ["unshare"],
      "decision": "forbidden",
      "justification": "Namespace manipulation can bypass sandbox"
    },
    {
      "pattern": ["chroot"],
      "decision": "forbidden",
      "justification": "Root filesystem change is a sandbox escape vector"
    },
    {
      "pattern": ["iptables"],
      "decision": "forbidden",
      "justification": "Firewall manipulation requires manual review"
    },
    {
      "pattern": ["nft"],
      "decision": "forbidden",
      "justification": "Firewall manipulation requires manual review"
    },
    {
      "pattern": ["crontab"],
      "decision": "prompt",
      "justification": "Cron job changes persist beyond session"
    },
    {
      "pattern": ["systemctl", ["enable", "disable"]],
      "decision": "prompt",
      "justification": "Service state changes persist beyond session"
    },
    {
      "pattern": ["shutdown"],
      "decision": "forbidden",
      "justification": "System shutdown — use manually with sudo"
    },
    {
      "pattern": ["reboot"],
      "decision": "forbidden",
      "justification": "System reboot — use manually with sudo"
    },
    {
      "pattern": ["dd", "if="],
      "decision": "forbidden",
      "justification": "Raw disk copy is destructive"
    },
    {
      "pattern": ["mkfs"],
      "decision": "forbidden",
      "justification": "Filesystem creation is destructive"
    },
    {
      "pattern": [":(){ :|:& };:"],
      "decision": "forbidden",
      "justification": "Fork bomb pattern"
    },
    {
      "pattern": ["curl", "*", "|", "*", "sh"],
      "decision": "forbidden",
      "justification": "Piping curl to shell — use package manager instead"
    },
    {
      "pattern": ["wget", "*", "|", "*", "sh"],
      "decision": "forbidden",
      "justification": "Piping wget to shell — use package manager instead"
    },
    {
      "pattern": [">", "/dev", "sd", "*"],
      "decision": "forbidden",
      "justification": "Writing directly to block device"
    }
  ],
  "banned_prefixes": [
    ["python3", "-c"],
    ["python", "-c"],
    ["python3"],
    ["python"],
    ["bash", "-c"],
    ["sh", "-c"],
    ["zsh", "-c"],
    ["node", "-e"],
    ["perl", "-e"],
    ["ruby", "-e"],
    ["php", "-r"],
    ["lua", "-e"],
    ["env", "bash"],
    ["env", "sh"]
  ]
}
